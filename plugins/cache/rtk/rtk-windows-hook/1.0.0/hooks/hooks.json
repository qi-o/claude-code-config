{
  "description": "RTK Windows hook - rewrites supported commands to use rtk for compact output",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/rtk-hook.cjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
