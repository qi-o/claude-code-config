{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "node \"C:\\Users\\ZDS\\.claude\\hooks\\gateguard.cjs\"",
          "timeout": 5000,
          "id": "pre:gateguard-edit"
        }],
        "description": "Fact-forcing gate: block first edit per file, demand investigation"
      },
      {
        "matcher": "Bash",
        "hooks": [{
          "type": "command",
          "command": "node \"C:\\Users\\ZDS\\.claude\\hooks\\gateguard.cjs\"",
          "timeout": 5000,
          "id": "pre:gateguard-bash"
        }],
        "description": "Fact-forcing gate for destructive bash + git push warning"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [{
          "type": "command",
          "command": "node \"C:\\Users\\ZDS\\.claude\\hooks\\format-accumulator.cjs\"",
          "timeout": 3000,
          "id": "post:format-accumulator"
        }],
        "description": "Accumulate edited file paths for batch formatting at Stop"
      },
      {
        "matcher": "Edit",
        "hooks": [{
          "type": "command",
          "command": "node \"C:\\Users\\ZDS\\.claude\\hooks\\debug-detect.cjs\"",
          "timeout": 3000,
          "id": "post:debug-detect"
        }],
        "description": "Warn about debug statements (console.log / print()) after edits"
      },
      {
        "matcher": "Read",
        "hooks": [{
          "type": "command",
          "command": "node \"C:\\Users\\ZDS\\.claude\\hooks\\read-injection-scanner.cjs\"",
          "timeout": 5000,
          "id": "post:read-injection-scanner"
        }],
        "description": "Scan Read tool output for prompt injection, summarization-survival, invisible Unicode"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [{
          "type": "command",
          "command": "node \"C:\\Users\\ZDS\\.claude\\hooks\\format-batch.cjs\"",
          "timeout": 120000,
          "id": "stop:format-batch"
        }],
        "description": "Batch format Python (Black) and JS/TS (Prettier) files"
      }
    ]
  }
}
